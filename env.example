# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in all values before running docker compose
# NEVER commit .env — it contains real secrets
# ═══════════════════════════════════════════════════════════════

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...    # required

# ── LangSmith tracing (optional but recommended) ────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_PROJECT=ProductionRAG

# ── PostgreSQL ──────────────────────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password

# IMPORTANT: .env does NOT support variable interpolation.
# DATABASE_URL must use the EXACT same password as POSTGRES_PASSWORD.
# If you change POSTGRES_PASSWORD, update DATABASE_URL too.
DATABASE_URL=postgresql://postgres:change_me_strong_password@postgres:5432/ragdb

# ── Redis ───────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# IMPORTANT: Same rule as above — must use the literal password value.
REDIS_URL=redis://:change_me_redis_password@redis:6379

# ── Qdrant ──────────────────────────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=documents

# ── Application ─────────────────────────────────────────────────
PDF_DIR=/app/pdfs
RERANKER_BACKEND=baai                         # baai | flashrank  - selection

# ── Security ────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=generate_a_64_char_hex_string_here

# Set ONCE for first startup, then REMOVE this line entirely.
# Leaving it set resets admin password on every container restart.
ADMIN_PASSWORD=set_once_then_delete_this_line

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# Use your actual domain in production, not localhost
ALLOWED_ORIGINS=http://localhost:3000

# ── Celery ──────────────────────────────────────────────────────
# Tune to your RAM: concurrency × 4 × 64 × ~6KB ≈ RAM needed per worker
CELERY_WORKER_CONCURRENCY=2
GUNICORN_WORKERS=4

# ── Monitoring ──────────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=change_me_flower_password
GRAFANA_PASSWORD=change_me_grafana_password

# ── Feature flags ───────────────────────────────────────────────
# Set DOCS_ENABLED=true in development to access /docs (Swagger UI)
# Always false in production
DOCS_ENABLED=false

# Never true in production — exposes internal agent state
DEBUG_ENDPOINTS_ENABLED=false
